  "panels": [
    {
      "type": "stat",
      "title": "Streamer rows/sec",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "rate(gpu_telemetry_streamer_rows_published_total[1m])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "rps", "decimals": 1}}
    },
    {
      "type": "stat",
      "title": "Collector rows inserted/sec",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "rate(gpu_telemetry_collector_rows_inserted_total[1m])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "rps", "decimals": 1}}
    },
    {
      "type": "stat",
      "title": "Backpressure / sec (HTTP 429)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "rate(gpu_telemetry_mq_backpressure_total[1m])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "rps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.1}]}}}
    },
    {
      "type": "stat",
      "title": "Persist errors / sec",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "rate(gpu_telemetry_collector_persist_errors_total[5m])", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "rps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.01}]}}}
    },
    {
      "type": "timeseries",
      "title": "MQ throughput — published vs consumed (per sec)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "rate(gpu_telemetry_mq_published_total[1m])", "legendFormat": "published", "refId": "A"},
        {"expr": "sum(rate(gpu_telemetry_mq_consumed_total[1m]))", "legendFormat": "consumed", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "rps"}}
    },
    {
      "type": "timeseries",
      "title": "Partition depth (unconsumed messages per partition)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "gpu_telemetry_mq_partition_length", "legendFormat": "p{{partition}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "Consumer offsets by (group, partition)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "gpu_telemetry_mq_consumer_offset", "legendFormat": "{{group}}/p{{partition}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "Collector persist latency (p50 / p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.5, sum by (le) (rate(gpu_telemetry_collector_persist_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(gpu_telemetry_collector_persist_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "API requests/sec by route + status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [{"expr": "sum by (route, status) (rate(gpu_telemetry_api_requests_total[1m]))", "legendFormat": "{{route}} {{status}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "rps"}}
    },
    {
      "type": "timeseries",
      "title": "API request latency p95 by route",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, route) (rate(gpu_telemetry_api_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}} p95", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    }
  ],
